{
  "themeName": "Limitless Modern Brutalist",
  "colors": {
    "brand": {
      "lime": "#A3E635",
      "purple": "#C3B5FD",
      "yellow": "#FACC15"
    },
    "neutral": {
      "black": "#000000",
      "white": "#FFFFFF",
      "zinc": {
        "900": "#18181b",
        "500": "#71717a",
        "100": "#f4f4f5"
      }
    }
  },
  "rounding": {
    "card": "40px",
    "section": "50px",
    "button": "30px",
    "pill": "9999px"
  },
  "typography": {
    "heading": "font-black italic tracking-tighter",
    "body": "font-medium leading-relaxed"
  },
  "shadows": {
    "soft": "0 20px 50px rgba(0,0,0,0.12)",
    "glow": "0 0 30px rgba(163,230,53,0.3)"
  }
}

